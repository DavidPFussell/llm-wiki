{
  "compilerOptions": {
    "composite": true,
    "target": "ES2020",
    "lib": ["ES2020"],
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "noEmit": true,
    "tsBuildInfoFile": "./.tsbuildinfo/node.tsbuildinfo"
  },
  "include": ["vite.config.ts", "server/**/*.ts"]
}
